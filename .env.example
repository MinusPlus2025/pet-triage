# 选择模型 provider：deepseek（默认）/ qwen / gemini
VITE_MODEL_PROVIDER=deepseek

# DeepSeek（默认，文本模型，三个预置案例足够跑通）
VITE_DEEPSEEK_API_KEY=在这里粘贴你的key
# 可选，默认 deepseek-chat；如需切换到 v4 可填 deepseek-v4-pro
# VITE_DEEPSEEK_MODEL=deepseek-chat

# 通义千问 Qwen（切到 qwen 时使用，支持图片）
VITE_QWEN_API_KEY=在这里粘贴你的key

# Gemini（切到 gemini 时使用，支持图片）
VITE_GEMINI_API_KEY=在这里粘贴你的key
